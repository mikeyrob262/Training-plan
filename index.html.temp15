var MTGT={HIGH:{cal:2500,pro:160,carb:310,fat:65},MOD:{cal:2200,pro:155,carb:250,fat:60},LOW:{cal:2000,pro:165,carb:180,fat:65}};
var DTYPE=["LOW","HIGH","MOD","HIGH","MOD","HIGH","LOW"];
var nutrDate='',curMeal='breakfast';

function getTodayKey(){var d=new Date();return d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate();}
function getNDay(k){if(!st.nl)st.nl={};if(!st.nl[k])st.nl[k]={meals:{breakfast:[],lunch:[],dinner:[],snacks:[]},water:0};return st.nl[k];}
function getDTots(k){var nd=getNDay(k),t={cal:0,p:0,c:0,f:0};['breakfast','lunch','dinner','snacks'].forEach(function(m){(nd.meals[m]||[]).forEach(function(i){t.cal+=i.cal||0;t.p+=i.p||0;t.c+=i.c||0;t.f+=i.f||0;});});return t;}
function getDType(k){var d=new Date(k),dow=d.getDay(),idx=dow===0?6:dow-1;return DTYPE[idx]||'MOD';}

function showNutr(){nutrDate=getTodayKey();renderNutr();showScreen('NUTR');}

function renderNutr(){
  var nd=getNDay(nutrDate),tot=getDTots(nutrDate);
  var dt=getDType(nutrDate),tgt=MTGT[dt]||MTGT.MOD;
  var d=new Date(nutrDate);
  var days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var ds=days[d.getDay()]+', '+months[d.getMonth()]+' '+d.getDate();
  var t=document.getElementById('NUTR');if(!t)return;

  function ring(pct,val,lbl,col){
    var r=26,circ=2*Math.PI*r,dash=circ*(Math.min(pct,100)/100),gap=circ-dash;
    return '<div style="text-align:center"><svg width="66" height="66" viewBox="0 0 66 66"><circle cx="33" cy="33" r="'+r+'" fill="none" stroke="var(--s3)" stroke-width="6"/><circle cx="33" cy="33" r="'+r+'" fill="none" stroke="'+col+'" stroke-width="6" stroke-dasharray="'+dash+' '+gap+'" transform="rotate(-90 33 33)" stroke-linecap="round"/><text x="33" y="37" text-anchor="middle" font-size="12" font-weight="700" fill="var(--t1)" font-family="-apple-system,sans-serif">'+val+'</text></svg><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:'+col+';margin-top:2px">'+lbl+'</div></div>';
  }

  var h='<div style="padding:14px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--b1)"><button class="back-btn" id="nutr-back">&#8592; Back</button><div style="font-size:19px;font-weight:800">Nutrition</div></div>';
  h+='<div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px 0"><button id="nutr-prev" style="background:var(--s2);border:1px solid var(--b1);color:var(--t2);width:34px;height:34px;border-radius:50%;font-size:20px;cursor:pointer">&#8249;</button><div style="text-align:center"><div style="font-size:15px;font-weight:700">'+ds+'</div><div style="font-size:11px;color:var(--t3);margin-top:2px">'+dt+' CARB DAY &middot; '+tgt.cal+' cal target</div></div><button id="nutr-next" style="background:var(--s2);border:1px solid var(--b1);color:var(--t2);width:34px;height:34px;border-radius:50%;font-size:20px;cursor:pointer">&#8250;</button></div>';
  h+='<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:14px 16px 0">'+ring(Math.round(tot.cal/tgt.cal*100),tot.cal,'KCAL','#FF7A45')+ring(Math.round(tot.p/tgt.pro*100),tot.p+'g','PROTEIN','#00C896')+ring(Math.round(tot.c/tgt.carb*100),tot.c+'g','CARBS','#4D9FFF')+ring(Math.round(tot.f/tgt.fat*100),tot.f+'g','FAT','#A78BFA')+'</div>';
  h+='<div style="background:var(--s1);margin:12px 16px 0;border-radius:14px;border:1px solid var(--b1);padding:13px 16px"><div style="display:flex;justify-content:space-between;align-items:center"><div style="font-size:13px;font-weight:700">&#128167; Water</div><div style="display:flex;align-items:center;gap:10px"><button id="water-minus" style="background:var(--s2);border:1px solid var(--b1);color:var(--t2);width:30px;height:30px;border-radius:50%;font-size:18px;cursor:pointer">&minus;</button><span style="font-size:16px;font-weight:800;min-width:50px;text-align:center">'+(nd.water||0)+'/8</span><button id="water-plus" style="background:rgba(0,200,150,.12);border:1px solid rgba(0,200,150,.2);color:var(--green);width:30px;height:30px;border-radius:50%;font-size:18px;cursor:pointer">+</button></div></div><div style="height:5px;background:var(--s3);border-radius:3px;margin-top:10px"><div style="height:5px;background:var(--blue);border-radius:3px;width:'+Math.min(100,Math.round((nd.water||0)/8*100))+'%"></div></div></div>';

  var meals=['breakfast','lunch','dinner','snacks'];
  var emojis={breakfast:'&#127749;',lunch:'&#9728;&#65039;',dinner:'&#127769;',snacks:'&#127822;'};
  meals.forEach(function(meal){
    var items=nd.meals[meal]||[];
    var mCal=items.reduce(function(a,b){return a+(b.cal||0);},0);
    h+='<div style="background:var(--s1);margin:10px 16px 0;border-radius:14px;border:1px solid var(--b1);overflow:hidden"><div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px"><span style="font-size:14px;font-weight:700">'+emojis[meal]+' '+meal.charAt(0).toUpperCase()+meal.slice(1)+'</span><div style="display:flex;align-items:center;gap:8px"><span style="font-size:12px;color:var(--t3)">'+mCal+' cal</span>';
    h+='<button class="add-food-btn" data-meal="'+meal+'" style="background:rgba(0,200,150,.12);border:1px solid rgba(0,200,150,.2);color:var(--green);font-size:12px;font-weight:700;padding:5px 12px;border-radius:20px;cursor:pointer;font-family:inherit">+ Add</button></div></div>';
    items.forEach(function(item,ii){
      h+='<div style="display:flex;justify-content:space-between;align-items:center;padding:9px 16px;border-top:1px solid var(--b1)"><div><div style="font-size:13px;font-weight:500;color:var(--t1)">'+item.n+'</div><div style="font-size:11px;color:var(--t3)">'+item.p+'g P &middot; '+item.c+'g C &middot; '+item.f+'g F</div></div><div style="display:flex;align-items:center;gap:6px"><span style="font-size:13px;font-weight:700;color:var(--t1)">'+item.cal+'</span><button data-meal="'+meal+'" data-idx="'+ii+'" onclick="rmFood(this.dataset.meal,parseInt(this.dataset.idx))" style="background:none;border:none;color:var(--red);font-size:18px;cursor:pointer;padding:0 4px">&times;</button></div></div>';
    });
    h+='</div>';
  });
  h+='<div style="height:50px"></div>';
  t.innerHTML=h;
  // Bind buttons after render
  t.querySelectorAll('.add-food-btn').forEach(function(btn){
    btn.addEventListener('click',function(){openFoodForMeal(this.getAttribute('data-meal'));});
  });
  t.querySelectorAll('.rm-food-btn').forEach(function(btn){
    btn.addEventListener('click',function(){rmFood(this.getAttribute('data-meal'),parseInt(this.getAttribute('data-idx')));});
  });
  var np=document.getElementById('nutr-prev');if(np)np.onclick=function(){nutrDelta(-1);};
  var nn=document.getElementById('nutr-next');if(nn)nn.onclick=function(){nutrDelta(1);};
  var wm=document.getElementById('water-minus');if(wm)wm.onclick=function(){updWater(-1);};
  var wp=document.getElementById('water-plus');if(wp)wp.onclick=function(){updWater(1);};
  var bb=document.getElementById('nutr-back');if(bb)bb.onclick=showTrain;
}

function openFoodForMeal(meal){curMeal=meal;openFoodModal();}
function nutrDelta(d){var dt=new Date(nutrDate);dt.setDate(dt.getDate()+d);nutrDate=dt.getFullYear()+'-'+(dt.getMonth()+1)+'-'+dt.getDate();renderNutr();}
function updWater(d){var nd=getNDay(nutrDate);nd.water=Math.max(0,Math.min(20,(nd.water||0)+d));sv();renderNutr();}
function rmFood(meal,ii){var nd=getNDay(nutrDate);nd.meals[meal].splice(ii,1);sv();renderNutr();}

function openFoodModal(){
  var old=document.getElementById('food-modal');if(old)old.remove();
  var modal=document.createElement('div');
  modal.id='food-modal';
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:300;display:flex;align-items:flex-end';
  var sheet=document.createElement('div');
  sheet.style.cssText='background:var(--s1);border-radius:22px 22px 0 0;width:100%;max-height:88vh;overflow-y:auto;padding-bottom:30px;border-top:1px solid rgba(255,255,255,.14)';
  sheet.innerHTML='<div style="width:40px;height:4px;background:rgba(255,255,255,.14);border-radius:2px;margin:13px auto 0"></div>'
    +'<div style="display:flex;justify-content:space-between;align-items:center;padding:13px 18px 8px">'
    +'<span style="font-size:18px;font-weight:800;color:var(--t1)">Add to '+curMeal+'</span>'
    +'<button id="food-close-btn" style="background:var(--s2);border:1px solid var(--b1);color:var(--t2);width:30px;height:30px;border-radius:50%;font-size:15px;cursor:pointer">&#10005;</button>'
    +'</div>'
    +'<div style="padding:0 16px 10px"><input id="food-srch" type="text" placeholder="Search foods..." style="width:100%;font-size:15px;background:var(--s2);border:1px solid var(--b2);border-radius:10px;padding:10px 14px;color:var(--t1);font-family:inherit"></div>'
    +'<div id="food-list" style="padding:0 16px"></div>';
  modal.appendChild(sheet);
  document.body.appendChild(modal);
  document.getElementById('food-close-btn').onclick=function(){modal.remove();};
  document.getElementById('food-srch').oninput=function(){renderFoodList(this.value.trim());};
  renderFoodList('');
}

function renderFoodList(q){
  var list=q?CF.filter(function(f){return f.n.toLowerCase().indexOf(q.toLowerCase())>=0;}):CF;
  var el=document.getElementById('food-list');if(!el)return;
  var h='';
  if(!q&&st.recentFoods&&st.recentFoods.length){
    h+='<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--blue);padding:4px 0 8px">Recently Used</div>';
    st.recentFoods.slice(0,5).forEach(function(f,i){h+=mkFoodRow(f,i);});
    h+='<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);padding:10px 0 6px">All Foods</div>';
  }
  list.forEach(function(f,i){h+=mkFoodRow(f,i);});
  h+='<div style="background:var(--s2);border-radius:12px;padding:14px;border:1px solid var(--b2);margin-top:12px">'
    +'<div style="font-size:12px;font-weight:700;color:var(--t1);margin-bottom:10px">+ Add custom food</div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:8px">'
    +'<input id="cf-n" type="text" placeholder="Food name" style="font-size:13px;border:1px solid var(--b2);border-radius:8px;padding:8px 10px;background:var(--s1);color:var(--t1);font-family:inherit;grid-column:1/-1">'
    +'<input id="cf-cal" type="number" placeholder="Calories" style="font-size:13px;border:1px solid var(--b2);border-radius:8px;padding:8px 10px;background:var(--s1);color:var(--t1);font-family:inherit">'
    +'<input id="cf-p" type="number" placeholder="Protein g" style="font-size:13px;border:1px solid var(--b2);border-radius:8px;padding:8px 10px;background:var(--s1);color:var(--t1);font-family:inherit">'
    +'<input id="cf-c" type="number" placeholder="Carbs g" style="font-size:13px;border:1px solid var(--b2);border-radius:8px;padding:8px 10px;background:var(--s1);color:var(--t1);font-family:inherit">'
    +'<input id="cf-f" type="number" placeholder="Fat g" style="font-size:13px;border:1px solid var(--b2);border-radius:8px;padding:8px 10px;background:var(--s1);color:var(--t1);font-family:inherit">'
    +'</div>'
    +'<button id="cf-add-btn" style="background:linear-gradient(135deg,#00C896,#0095C8);border:none;color:white;font-size:14px;font-weight:700;padding:11px;border-radius:10px;width:100%;cursor:pointer">Add to '+curMeal+'</button>'
    +'</div>';
  el.innerHTML=h;
  document.getElementById('cf-add-btn').onclick=addCustomFood;
  // Bind add buttons
  el.querySelectorAll('.food-add-btn').forEach(function(btn){
    btn.onclick=function(){
      var fi=parseInt(this.dataset.fi);
      var qEl=this.parentNode.querySelector('.qty');
      var q=parseFloat(qEl?qEl.textContent:1)||1;
      addFoodItemByIdx(fi,q);
    };
  });
  // Bind qty buttons
  el.querySelectorAll('.qty-minus').forEach(function(btn){btn.onclick=function(){adjQty(this,-1);};});
  el.querySelectorAll('.qty-plus').forEach(function(btn){btn.onclick=function(){adjQty(this,1);};});
}

function mkFoodRow(f,i){
  return '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--b1)"><div style="flex:1"><div style="font-size:13px;font-weight:600;color:var(--t1)">'+f.n+'</div><div style="font-size:11px;color:var(--t3)">'+(f.srv||'1 serving')+' &middot; '+f.cal+' cal &middot; '+f.p+'g P &middot; '+f.c+'g C &middot; '+f.f+'g F</div></div><div style="display:flex;align-items:center;gap:6px;margin-left:8px"><div style="display:flex;align-items:center;background:var(--s2);border:1px solid var(--b2);border-radius:20px;padding:1px 3px"><button class="qty-minus" style="background:none;border:none;color:var(--t2);font-size:15px;cursor:pointer;width:22px;height:22px">&minus;</button><span class="qty" style="font-size:12px;font-weight:700;color:var(--t1);min-width:14px;text-align:center">1</span><button class="qty-plus" style="background:none;border:none;color:var(--t2);font-size:15px;cursor:pointer;width:22px;height:22px">+</button></div><button class="food-add-btn" data-fi="'+i+'" style="background:rgba(0,200,150,.12);border:1px solid rgba(0,200,150,.2);color:var(--green);font-size:12px;font-weight:700;padding:5px 11px;border-radius:20px;cursor:pointer;font-family:inherit">Add</button></div></div>';
}

function adjQty(btn,d){var q=btn.parentNode.querySelector('.qty');var v=parseFloat(q.textContent)||1;v=Math.max(0.5,v+d);q.textContent=v%1===0?v:v.toFixed(1);}

function addFoodItemByIdx(fi,q){
  var f=CF[fi];if(!f)return;
  var nd=getNDay(nutrDate);
  nd.meals[curMeal].push({n:q===1?f.n:f.n+' (x'+q+')',cal:Math.round(f.cal*q),p:Math.round(f.p*q*10)/10,c:Math.round(f.c*q*10)/10,f:Math.round(f.f*q*10)/10});
  if(!st.recentFoods)st.recentFoods=[];
  if(!st.recentFoods.find(function(r){return r.n===f.n;}))st.recentFoods.unshift(f);
  if(st.recentFoods.length>8)st.recentFoods=st.recentFoods.slice(0,8);
  sv();var m=document.getElementById('food-modal');if(m)m.remove();renderNutr();toast('Added '+f.n+'!');
}

function addCustomFood(){
  var n=document.getElementById('cf-n'),c=document.getElementById('cf-cal'),p=document.getElementById('cf-p'),cb=document.getElementById('cf-c'),fb=document.getElementById('cf-f');
  if(!n||!n.value.trim()){toast('Enter a name');return;}
  if(!c||!parseInt(c.value)){toast('Enter calories');return;}
  var food={n:n.value.trim(),cal:parseInt(c.value)||0,p:parseFloat(p.value)||0,c:parseFloat(cb.value)||0,f:parseFloat(fb.value)||0,srv:'custom'};
  CF.push(food);if(!st.cf)st.cf=[];st.cf.push(food);
  var nd=getNDay(nutrDate);nd.meals[curMeal].push({n:food.n,cal:food.cal,p:food.p,c:food.c,f:food.f});
  sv();var m=document.getElementById('food-modal');if(m)m.remove();renderNutr();toast('Added '+food.n+'!');
}

// ── ACTIVITY ───────────────────────────────────────────────
function showAct(){renderAct();showScreen('ACT');}

function renderAct(){
  if(!st.acts)st.acts=[];
  var acts=st.acts,tr=0,ru=0,dist=0,tss=0;
  acts.forEach(function(a){if(a.type==='Run')ru++;else tr++;dist+=parseFloat(a.dist)||0;tss+=parseFloat(a.tss)||0;});
  var t=document.getElementById('ACT');if(!t)return;
  var h='<div style="padding:14px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--b1)"><div style="display:flex;align-items:center;gap:10px"><button class="back-btn" id="act-back-btn">&#8592; Back</button><div style="font-size:19px;font-weight:800">Activities</div></div><button id="act-log-btn" style="background:linear-gradient(135deg,#00C896,#0095C8);border:none;color:white;font-size:13px;font-weight:700;padding:7px 14px;border-radius:20px;cursor:pointer">+ Log</button></div>';
  h+='<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:14px 16px 0">'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:12px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Rides</div><div style="font-size:22px;font-weight:800;color:var(--green)">'+tr+'</div></div>'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:12px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Runs</div><div style="font-size:22px;font-weight:800;color:var(--blue)">'+ru+'</div></div>'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:12px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Miles</div><div style="font-size:22px;font-weight:800;color:var(--gold)">'+dist.toFixed(0)+'</div></div>'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:12px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">TSS</div><div style="font-size:22px;font-weight:800;color:var(--purple)">'+tss.toFixed(0)+'</div></div>'
    +'</div>';
  if(acts.length){
    var sorted=acts.slice().sort(function(a,b){return new Date(b.date)-new Date(a.date);});
    sorted.forEach(function(a,i){
      var em={Ride:'&#128693;',Zwift:'&#9889;',Run:'&#127939;','Chase 2':'&#128293;',Strength:'&#128170;',Swim:'&#127944;'}[a.type]||'&#127939;';
      var dd=new Date(a.date);
      var dys=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'],mns=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      h+='<div style="background:var(--s1);margin:10px 16px 0;border-radius:14px;border:1px solid var(--b1);overflow:hidden"><div style="padding:13px 16px 10px"><div style="display:flex;justify-content:space-between;margin-bottom:8px"><div><div style="font-size:15px;font-weight:700;color:var(--t1)">'+em+' '+a.name+'</div><div style="font-size:11px;color:var(--t3);margin-top:2px">'+dys[dd.getDay()]+', '+mns[dd.getMonth()]+' '+dd.getDate()+'</div></div>';
      h+='<button data-idx="'+i+'" class="del-act-btn" style="background:none;border:none;color:var(--red);font-size:18px;cursor:pointer">&times;</button></div>';
      h+='<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:5px">';
      if(a.dist)h+='<div style="background:var(--s2);border-radius:8px;padding:7px;text-align:center"><div style="font-size:9px;color:var(--t3);margin-bottom:2px">DIST</div><div style="font-size:12px;font-weight:700;color:var(--t1)">'+a.dist+' mi</div></div>';
      if(a.time)h+='<div style="background:var(--s2);border-radius:8px;padding:7px;text-align:center"><div style="font-size:9px;color:var(--t3);margin-bottom:2px">TIME</div><div style="font-size:12px;font-weight:700;color:var(--t1)">'+a.time+'</div></div>';
      if(a.power)h+='<div style="background:var(--s2);border-radius:8px;padding:7px;text-align:center"><div style="font-size:9px;color:var(--t3);margin-bottom:2px">POWER</div><div style="font-size:12px;font-weight:700;color:var(--t1)">'+a.power+'w</div></div>';
      if(a.hr)h+='<div style="background:var(--s2);border-radius:8px;padding:7px;text-align:center"><div style="font-size:9px;color:var(--t3);margin-bottom:2px">HR</div><div style="font-size:12px;font-weight:700;color:var(--t1)">'+a.hr+'</div></div>';
      if(a.tss)h+='<div style="background:var(--s2);border-radius:8px;padding:7px;text-align:center"><div style="font-size:9px;color:var(--t3);margin-bottom:2px">TSS</div><div style="font-size:12px;font-weight:700;color:var(--t1)">'+a.tss+'</div></div>';
      if(a.elev)h+='<div style="background:var(--s2);border-radius:8px;padding:7px;text-align:center"><div style="font-size:9px;color:var(--t3);margin-bottom:2px">ELEV</div><div style="font-size:12px;font-weight:700;color:var(--t1)">'+a.elev+"'</div></div>";
      h+='</div>';
      if(a.notes)h+='<div style="font-size:12px;color:var(--t3);font-style:italic;margin-top:8px">&ldquo;'+a.notes+'&rdquo;</div>';
      h+='</div></div>';
    });
  } else {
    h+='<div style="padding:40px;text-align:center;color:var(--t3)"><div style="font-size:40px;margin-bottom:8px">&#128693;</div><div style="font-size:14px">No activities yet</div><div style="font-size:12px;margin-top:4px">Tap + Log to add your first one</div></div>';
  }
  h+='<div style="height:50px"></div>';
  t.innerHTML=h;
  // Bind all buttons after render
  var ab=document.getElementById('act-back-btn');if(ab)ab.onclick=showTrain;
  var lb=document.getElementById('act-log-btn');if(lb)lb.onclick=openActAdd;
  t.querySelectorAll('.del-act-btn').forEach(function(btn){
    btn.addEventListener('click',function(){delAct(parseInt(this.getAttribute('data-idx')));});
  });
}

function delAct(i){
  if(!st.acts)return;
  var sorted=st.acts.slice().sort(function(a,b){return new Date(b.date)-new Date(a.date);});
  var act=sorted[i];var ri=st.acts.indexOf(act);
  if(ri>=0){st.acts.splice(ri,1);sv();renderAct();}
}

function openActAdd(){
  var old=document.getElementById('act-modal');if(old)old.remove();
  var modal=document.createElement('div');
  modal.id='act-modal';
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:300;display:flex;align-items:flex-end';
  var d=new Date();
  var ds=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
  var sheet=document.createElement('div');
  sheet.style.cssText='background:var(--s1);border-radius:22px 22px 0 0;width:100%;max-height:90vh;overflow-y:auto;padding-bottom:30px;border-top:1px solid rgba(255,255,255,.14)';
  sheet.innerHTML='<div style="width:40px;height:4px;background:rgba(255,255,255,.14);border-radius:2px;margin:13px auto 0"></div>'
    +'<div style="display:flex;justify-content:space-between;align-items:center;padding:13px 18px 10px"><span style="font-size:18px;font-weight:800;color:var(--t1)">Log Activity</span><button id="act-close-btn" style="background:var(--s2);border:1px solid var(--b1);color:var(--t2);width:30px;height:30px;border-radius:50%;font-size:15px;cursor:pointer">&#10005;</button></div>'
    +'<div style="padding:0 16px">'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">'
    +'<div><div class="ci-lbl">Type</div><select id="act-type" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"><option value="Ride">Outdoor Ride</option><option value="Zwift">Zwift</option><option value="Run">Run</option><option value="Swim">Swim</option><option value="Chase 2">Chase 2</option><option value="Strength">Strength</option></select></div>'
    +'<div><div class="ci-lbl">Date</div><input id="act-date" type="date" value="'+ds+'" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'</div>'
    +'<div style="margin-bottom:10px"><div class="ci-lbl">Name</div><input id="act-name" type="text" placeholder="e.g. Thursday Chase 2 W1" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 12px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">'
    +'<div><div class="ci-lbl">Distance (mi)</div><input id="act-dist" type="number" step="0.1" placeholder="24.5" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'<div><div class="ci-lbl">Time (h:mm)</div><input id="act-time" type="text" placeholder="1:45" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'<div><div class="ci-lbl">Avg Power (w)</div><input id="act-power" type="number" placeholder="178" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'<div><div class="ci-lbl">Avg HR (bpm)</div><input id="act-hr" type="number" placeholder="142" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'<div><div class="ci-lbl">TSS</div><input id="act-tss" type="number" placeholder="auto" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'<div><div class="ci-lbl">Elevation (ft)</div><input id="act-elev" type="number" placeholder="1200" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 10px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit"></div>'
    +'</div>'
    +'<div style="margin-bottom:14px"><div class="ci-lbl">Notes</div><textarea id="act-notes" rows="2" placeholder="How did it feel?" style="font-size:14px;border:1px solid var(--b2);border-radius:10px;padding:9px 12px;width:100%;background:var(--s2);color:var(--t1);font-family:inherit;resize:none"></textarea></div>'
    +'<button id="act-save-btn" style="background:linear-gradient(135deg,#00C896,#0095C8);border:none;color:white;font-size:16px;font-weight:700;padding:15px;border-radius:13px;width:100%;cursor:pointer">Save Activity</button>'
    +'</div><div style="height:20px"></div>';
  modal.appendChild(sheet);document.body.appendChild(modal);
  document.getElementById('act-close-btn').onclick=function(){modal.remove();};
  document.getElementById('act-save-btn').onclick=saveAct;
}

function saveAct(){
  var fld=function(id){var e=document.getElementById(id);return e?e.value:'';};
  if(!st.acts)st.acts=[];
  st.acts.push({type:fld('act-type'),name:fld('act-name')||fld('act-type')+' W'+cw,date:fld('act-date'),dist:fld('act-dist'),time:fld('act-time'),power:fld('act-power'),hr:fld('act-hr'),tss:fld('act-tss'),elev:fld('act-elev'),notes:fld('act-notes')});
  sv();var m=document.getElementById('act-modal');if(m)m.remove();renderAct();toast('Activity saved!');
}

document.getElementById('btn-nutr').onclick=showNutr; 
  document.getElementById('btn-act').onclick=showAct; 
  document.getElementById('btn-set').onclick=showSet;
  document.getElementById('btn-pv').onclick=function(){GW(cw-1);};
  document.getElementById('btn-nx').onclick=function(){GW(cw+1);};
  document.getElementById('btn-wt').onclick=openPk;
  document.getElementById('pk-bg').onclick=closePk;
  
  if(st.cf){st.cf.forEach(function(f){if(!CF.find(function(x){return x.n===f.n;}))CF.push(f);});}
  // Restore week 1 state
  restoreW(1);
  updHdr();
  updDots();
};
</script>
</body>
</html>
