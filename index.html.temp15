<div class="nt-row"><span class="nt-day">Mon</span><span><span class="nbdg" style="background:#1a1a2e;color:#8888aa">REST</span></span><span class="nt-v">1,900-2,000</span><span class="nt-c">LOW</span><span class="nt-v">High protein + veg</span><span class="nt-v">—</span><span class="nt-v">—</span><span class="nt-chk" id="nc17_0" onclick="TN(17,0)"></span></div>
<div class="nt-row alt"><span class="nt-day">Tue</span><span><span class="nbdg" style="background:#0a4a30;color:#7dd4b0">EASY</span></span><span class="nt-v">2,100-2,200</span><span class="nt-c">MOD</span><span class="nt-v">Light fuel day</span><span class="nt-v">Small snack if hungry</span><span class="nt-v">Greek yogurt or shake</span><span class="nt-chk" id="nc17_1" onclick="TN(17,1)"></span></div>
<div class="nt-row"><span class="nt-day">Wed</span><span><span class="nbdg" style="background:#0a4a30;color:#7dd4b0">EASY</span></span><span class="nt-v">2,000-2,100</span><span class="nt-c">MOD</span><span class="nt-v">Protein focus</span><span class="nt-v">Banana if 2+ hrs since eating</span><span class="nt-v">Greek yogurt or shake</span><span class="nt-chk" id="nc17_2" onclick="TN(17,2)"></span></div>
<div class="nt-row alt"><span class="nt-day">Thu</span><span><span class="nbdg" style="background:#0d3460;color:#90b8e0">MOD</span></span><span class="nt-v">2,200-2,400</span><span class="nt-c">MOD</span><span class="nt-v">Group ride fuel</span><span class="nt-v">Full meal 2-2.5 hrs before</span><span class="nt-v">Shake + banana after</span><span class="nt-chk" id="nc17_3" onclick="TN(17,3)"></span></div>
<div class="nt-row"><span class="nt-day">Fri</span><span><span class="nbdg" style="background:#1a1a2e;color:#8888aa">REST</span></span><span class="nt-v">1,900-2,000</span><span class="nt-c">LOW</span><span class="nt-v">Recovery day</span><span class="nt-v">—</span><span class="nt-v">—</span><span class="nt-chk" id="nc17_4" onclick="TN(17,4)"></span></div>
<div class="nt-row alt"><span class="nt-day">Sat</span><span><span class="nbdg" style="background:#0a4a30;color:#7dd4b0">EASY</span></span><span class="nt-v">2,100-2,200</span><span class="nt-c">MOD</span><span class="nt-v">Easy ride food</span><span class="nt-v">Light snack 1 hr before</span><span class="nt-v">Shake or yogurt after</span><span class="nt-chk" id="nc17_5" onclick="TN(17,5)"></span></div>
<div class="nt-row"><span class="nt-day">Sun</span><span><span class="nbdg" style="background:#1a1a2e;color:#8888aa">REST</span></span><span class="nt-v">1,900-2,000</span><span class="nt-c">LOW</span><span class="nt-v">Meal prep day</span><span class="nt-v">—</span><span class="nt-v">—</span><span class="nt-chk" id="nc17_6" onclick="TN(17,6)"></span></div>
</div>
<div class="sec-title">Weekly Check-In</div>
<div class="ci-card">
  <div class="ci-hdr">End of Week 17</div>
  <div class="ci-grid">
    <div class="ci-f"><div class="ci-lbl">Weight (lbs)</div><input class="ci-in" type="number" placeholder="—" id="cw17" onchange="SC(17,'weight',this.value)"></div>
    <div class="ci-f"><div class="ci-lbl">Resting HR</div><input class="ci-in" type="number" placeholder="—" id="cr17" onchange="SC(17,'rhr',this.value)"></div>
    <div class="ci-f"><div class="ci-lbl">Energy (1-10)</div><input class="ci-in" type="number" min="1" max="10" placeholder="—" id="ce17" onchange="SC(17,'energy',this.value)"></div>
    <div class="ci-f"><div class="ci-lbl">Sleep (hrs)</div><input class="ci-in" type="number" step="0.5" placeholder="—" id="cs17" onchange="SC(17,'sleep',this.value)"></div>
  </div>
  <div class="ci-notes">
    <div class="ci-lbl" style="margin-bottom:6px">Notes</div>
    <textarea class="ci-ta" rows="2" placeholder="How did the week feel?" id="cn17" onchange="SC(17,'notes',this.value)"></textarea>
  </div>
</div>
<div style="height:50px"></div>
</div>
</div>

<div id="PROG" style="display:none"></div>
<div id="NUTR" style="display:none"></div>
<div id="ACT"  style="display:none"></div>
<div id="SET"  style="display:none"></div>

<div class="pk-bg" id="pk-bg"></div>
<div class="pk-sheet" id="pk-sheet">
  <div class="mhdl"></div>
  <div style="font-size:17px;font-weight:800;color:var(--t1);padding:12px 16px 0">Jump to Week</div>
  <div class="pk-grid"><div class="pk-it" onclick="GW(1);closePk()"><div class="pk-n">1</div><div class="pk-p">Phase 1</div></div><div class="pk-it" onclick="GW(2);closePk()"><div class="pk-n">2</div><div class="pk-p">Phase 1</div></div><div class="pk-it" onclick="GW(3);closePk()"><div class="pk-n">3</div><div class="pk-p">Phase 1</div></div><div class="pk-it" onclick="GW(4);closePk()"><div class="pk-n">4</div><div class="pk-p">Phase 1</div></div><div class="pk-it" onclick="GW(5);closePk()"><div class="pk-n">5</div><div class="pk-p">Phase 2</div></div><div class="pk-it" onclick="GW(6);closePk()"><div class="pk-n">6</div><div class="pk-p">Phase 2</div></div><div class="pk-it" onclick="GW(7);closePk()"><div class="pk-n">7</div><div class="pk-p">Phase 2</div></div><div class="pk-it" onclick="GW(8);closePk()"><div class="pk-n">8</div><div class="pk-p">Phase 2</div></div><div class="pk-it" onclick="GW(9);closePk()"><div class="pk-n">9</div><div class="pk-p">Phase 2</div></div><div class="pk-it" onclick="GW(10);closePk()"><div class="pk-n">10</div><div class="pk-p">Phase 2</div></div><div class="pk-it" onclick="GW(11);closePk()"><div class="pk-n">11</div><div class="pk-p">Phase 3</div></div><div class="pk-it" onclick="GW(12);closePk()"><div class="pk-n">12</div><div class="pk-p">Phase 3</div></div><div class="pk-it" onclick="GW(13);closePk()"><div class="pk-n">13</div><div class="pk-p">Phase 3</div></div><div class="pk-it" onclick="GW(14);closePk()"><div class="pk-n">14</div><div class="pk-p">Phase 3</div></div><div class="pk-it" onclick="GW(15);closePk()"><div class="pk-n">15</div><div class="pk-p">Phase 3</div></div><div class="pk-it" onclick="GW(16);closePk()"><div class="pk-n">16</div><div class="pk-p">Phase 4</div></div><div class="pk-it" onclick="GW(17);closePk()"><div class="pk-n">17</div><div class="pk-p">Phase 4</div></div></div>
</div>

<div class="modal-bg" id="mod-A"></div>
<div class="modal-bg" id="mod-B"></div>

<script>
var cw=1, st={}, curSW=1;
try{var _s=localStorage.getItem('mta2');if(_s)st=JSON.parse(_s);}catch(e){}
function sv(){try{localStorage.setItem('mta2',JSON.stringify(st));}catch(e){}}
function ws(w){if(!st[w])st[w]={wo:{},nu:{},ci:{},fi:{},str:{}};return st[w];}

var WC={};
WC[1]=6;WC[2]=6;WC[3]=6;WC[4]=5;WC[5]=6;WC[6]=6;WC[7]=6;WC[8]=6;WC[9]=6;WC[10]=5;WC[11]=6;WC[12]=6;WC[13]=6;WC[14]=6;WC[15]=6;WC[16]=5;WC[17]=4;

var PHASES={};
PHASES[1]=["Foundation","Phase 1"];PHASES[2]=["Foundation","Phase 1"];PHASES[3]=["Foundation","Phase 1"];PHASES[4]=["Foundation","Phase 1"];PHASES[5]=["Aerobic Build","Phase 2"];PHASES[6]=["Aerobic Build","Phase 2"];PHASES[7]=["Aerobic Build","Phase 2"];PHASES[8]=["Aerobic Build","Phase 2"];PHASES[9]=["Aerobic Build","Phase 2"];PHASES[10]=["Aerobic Build","Phase 2"];PHASES[11]=["Race-Specific","Phase 3"];PHASES[12]=["Race-Specific","Phase 3"];PHASES[13]=["Race-Specific","Phase 3"];PHASES[14]=["Race-Specific","Phase 3"];PHASES[15]=["Race-Specific","Phase 3"];PHASES[16]=["Taper & Race","Phase 4"];PHASES[17]=["Taper & Race","Phase 4"];

var SWAPS={"Zwift":["Outdoor Ride","Easy Run","Swim Easy 30 min","Rest Day"],"Zwift Intervals":["Outdoor Ride Efforts","Track Intervals","Swim Intervals","Rest Day"],"Zwift Sweet Spot":["Outdoor Ride Tempo","Tempo Run","Rest Day"],"Zwift 2x20":["Outdoor 2x20","Tempo Run","Rest Day"],"Zwift Taper":["Easy Outdoor Ride","Easy Run","Rest Day"],"Zwift FTP TEST":["Outdoor FTP Test","Rest Day"],"Zwift Final 2x20":["Outdoor 2x20","Tempo Run","Rest Day"],"Chase 2":["Solo Ride","Zwift Intervals","Easy Ride","Rest Day"],"Easy Ride":["Easy Run","Zwift Zone 2","Swim Easy","Rest Day"],"Outdoor Ride":["Zwift Zone 2","Easy Run","Swim Steady","Rest Day"],"Easy Run":["Zwift Zone 2","Outdoor Ride","Swim Easy","Fartlek Run","Walk 30 min","Rest Day"],"Run + Strength B":["Strength B Only","Easy Run","Rest Day"],"Run Tempo Intro":["Tempo Run","Fartlek Run","Hill Repeats","Swim Steady","Rest Day"],"Run Tempo":["Tempo Run","Fartlek Run","400m Repeats x8","800m Repeats x6","Hill Repeats","Swim Intervals","Rest Day"],"Run Final Tempo":["Tempo Run","Fartlek Run","400m Repeats","Hill Repeats","Rest Day"],"Long Run":["Long Swim 45 min","Easy Bike 90 min","Run/Walk 60 min","Rest Day"],"Strength A":["Swim Easy 30 min","Rest Day"],"Swim Easy 30 min":["Easy Run","Zwift Zone 2","Rest Day"]};

var FBA=[["Goblet Squat","3","12","Feet shoulder-width, squat deep"],["Romanian Deadlift (RDL)","3","10","Hinge at hips, feel hamstrings"],["Bench Press","3","8","Full range, control descent"],["Push-up","3","15","Chest to floor, full lockout"],["Band Row","3","15","Squeeze shoulder blades"],["Dead Bug","3","10","Per side, lower back flat"]];
var FBB=[["Back Squat","3","8","Bar on traps, depth parallel"],["Single-Leg RDL","3","8","Per side, balance focus"],["Dumbbell Press","3","10","Full range of motion"],["Pull-up / Lat Pulldown","3","8","Full hang to chin"],["Dumbbell Row","3","12","Per side, elbow high"],["Plank","3","45s","Straight line, squeeze glutes"]];

function toast(m){var t=document.createElement('div');t.className='toast';t.textContent=m;document.body.appendChild(t);setTimeout(function(){t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(function(){t.remove();},400);},2500);}

function updDots(){
  for(var w=1;w<=17;w++){
    var el=document.getElementById('pd'+w);
    if(!el)continue;
    var s=ws(w),d=Object.values(s.wo).filter(Boolean).length;
    el.className='dot'+(w===cw?' cur':(d>=WC[w]&&WC[w]>0?' done':''));
  }
}

function updHdr(){
  var ph=PHASES[cw]||['Foundation','Phase 1'];
  document.getElementById('wph').textContent=ph[0];
  document.getElementById('pp').textContent=ph[1];
  var today=new Date();var days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];var months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];var dateStr=days[today.getDay()]+' '+months[today.getMonth()]+' '+today.getDate();document.getElementById('btn-wt').innerHTML='Week '+cw+' · '+dateStr+' <span style="font-size:12px;opacity:.4">&#9660;</span>';
  document.getElementById('btn-pv').disabled=cw===1;
  document.getElementById('btn-nx').disabled=cw===17;
}

function GW(w){
  if(w<1||w>17)return;
  var old=document.getElementById('W'+cw);
  if(old)old.style.display='none';
  cw=w;
  var nw=document.getElementById('W'+w);
  if(nw)nw.style.display='block';
  showTrain();
  updHdr();
  updDots();
  restoreW(w);
  window.scrollTo(0,0);
  closePk();
}

function showTrain(){
  document.getElementById('TRAIN').style.display='block';
  document.getElementById('PROG').style.display='none';
  document.getElementById('NUTR').style.display='none';
  document.getElementById('ACT').style.display='none';
  document.getElementById('SET').style.display='none';
}

function restoreW(w){
  var s=ws(w);
  Object.keys(s.wo).forEach(function(i){
    if(s.wo[i]){var e=document.getElementById('ck'+w+'_'+i);if(e){e.className='wo-chk on';e.textContent='✓';}}
  });
  Object.keys(s.nu).forEach(function(i){
    if(s.nu[i]){var e=document.getElementById('nc'+w+'_'+i);if(e){e.className='nt-chk on';e.textContent='✓';}}
  });
  var ci=s.ci||{};
  if(ci.weight){var e=document.getElementById('cw'+w);if(e)e.value=ci.weight;}
  if(ci.rhr){var e=document.getElementById('cr'+w);if(e)e.value=ci.rhr;}
  if(ci.energy){var e=document.getElementById('ce'+w);if(e)e.value=ci.energy;}
  if(ci.sleep){var e=document.getElementById('cs'+w);if(e)e.value=ci.sleep;}
  if(ci.notes){var e=document.getElementById('cn'+w);if(e)e.value=ci.notes;}
  Object.keys(s.fi).forEach(function(i){
    var fi=s.fi[i];
    if(fi.a){var e=document.getElementById('af'+w+'_'+i);if(e)e.value=fi.a;}
    if(fi.r){var e=document.getElementById('rf'+w+'_'+i);if(e)e.value=fi.r;}
  });
  Object.keys(s.swaps||{}).forEach(function(i){
    var e=document.getElementById('ws'+w+'_'+i);
    if(e){e.textContent=s.swaps[i];e.style.color='var(--blue)';}
  });
}

function TW(w,i){
  var s=ws(w);s.wo[i]=!s.wo[i];sv();
  var e=document.getElementById('ck'+w+'_'+i);
  if(e){e.className='wo-chk'+(s.wo[i]?' on':'');e.textContent=s.wo[i]?'✓':'';}
  updDots();
}
function TN(w,i){
  var s=ws(w);s.nu[i]=!s.nu[i];sv();
  var e=document.getElementById('nc'+w+'_'+i);
  if(e){e.className='nt-chk'+(s.nu[i]?' on':'');e.textContent=s.nu[i]?'✓':'';}
}
function SF(w,i,f,v){var s=ws(w);if(!s.fi[i])s.fi[i]={};s.fi[i][f]=v;sv();}
function SC(w,f,v){ws(w).ci[f]=v;sv();}

function openPk(){document.getElementById('pk-sheet').classList.add('open');document.getElementById('pk-bg').classList.add('open');var pks=document.querySelectorAll('.pk-it');pks.forEach(function(p,i){p.className='pk-it'+(i+1===cw?' cur':'');});}
function closePk(){document.getElementById('pk-sheet').classList.remove('open');document.getElementById('pk-bg').classList.remove('open');}

function doSwap(w,idx,btn){
  var existing=document.getElementById('sp'+w+'_'+idx);
  if(existing){existing.remove();return;}
  var sess=document.getElementById('ws'+w+'_'+idx);
  var sessName=sess?sess.textContent:'';
  var opts=SWAPS[sessName]||['Outdoor Ride','Easy Run','Zwift Zone 2','Rest Day'];
  var card=document.getElementById('wc'+w+'_'+idx);
  if(!card)return;
  var p=document.createElement('div');
  p.id='sp'+w+'_'+idx;p.className='swap-panel';
  var html='<div class="swap-lbl">Swap with:</div><div class="swap-opts">';
  opts.forEach(function(o){
    html+='<button class="swap-opt" onclick="applySwap('+w+','+idx+',this.textContent)">'+o+'</button>';
  });
  html+='<button class="swap-cancel" onclick="rmSwap('+w+','+idx+')">Cancel</button>';
  html+='</div>';
  p.innerHTML=html;
  card.appendChild(p);
}


function rmSwap(w,i){var p=document.getElementById('sp'+w+'_'+i);if(p)p.remove();}

function applySwap(w,idx,val){
  var s=ws(w);if(!s.swaps)s.swaps={};s.swaps[idx]=val;sv();
  var e=document.getElementById('ws'+w+'_'+idx);
  if(e){e.textContent=val;e.style.color='var(--blue)';}
  var p=document.getElementById('sp'+w+'_'+idx);if(p)p.remove();
  toast('Swapped to: '+val);
}

function openStr(letter,w){
  curSW=w;
  var exs=letter==='A'?FBA:FBB;
  var modal=document.getElementById('mod-'+letter);
  var s=ws(w);
  var html='<div class="modal-sh"><div class="mhdl"></div>'
    +'<div class="mhdr"><div><div class="mtit">💪 Full Body '+letter+'</div>'
    +'<div style="font-size:12px;color:var(--t3)">Week '+w+'</div></div>'
    +'<button class="mclose" onclick="closeStr(letter)">✕</button></div>';
  var altMap={0:['Goblet Squat','Back Squat','Bulgarian Split Squat','Leg Press'],1:['Romanian Deadlift','Conventional Deadlift','Single-Leg RDL','Hip Thrust'],2:['Bench Press','Incline Bench Press','Overhead Press','Dumbbell Press'],3:['Push-up','Dumbbell Press','Incline Press'],4:['Band Row','Dumbbell Row','Pull-up','Cable Row'],5:['Dead Bug','Plank','Ab Wheel','Pallof Press']};
  exs.forEach(function(ex,ei){
    var alts=(altMap[ei]||[]).filter(function(a){return a!==ex[0];});
    var opts=alts.map(function(a){return '<option value="'+a+'">'+a+'</option>';}).join('');
    html+='<div class="ex-c"><div class="ex-h"><div><div class="ex-nm" id="en_'+letter+'_'+ei+'">'+ex[0]+'</div><div class="ex-tip">'+ex[3]+'</div></div>'
    html+='<div class="ex-c"><div class="ex-h"><div><div class="ex-nm" id="en_'+letter+'_'+ei+'">'+ex[0]+'</div><div class="ex-tip">'+ex[3]+'</div></div>'
      +'<select class="ex-sw" data-l="'+letter+'" data-ei="'+ei+'" onchange="swExData(this)"><option value="">Swap</option>'+opts+'</select></div>'
      +'<div class="set-hr"><div class="sn" style="font-size:10px;color:var(--t3)">SET</div><div class="sp" style="font-size:10px;color:var(--t3)">PREV</div><div style="font-size:10px;color:var(--t3);text-align:center">LBS</div><div style="font-size:10px;color:var(--t3);text-align:center">REPS</div><div></div></div>';
    for(var si=0;si<3;si++){
      var sd=(s.str&&s.str[letter]&&s.str[letter][ei]&&s.str[letter][ei][si])||{};
      var prev=getPrev(letter,w,ei,si);
      html+='<div class="set-r'+(sd.done?' done':'')+'" id="sr_'+letter+'_'+ei+'_'+si+'">'
        +'<div class="sn">'+(si+1)+'</div>'
        +'<div class="sp" style="color:var(--blue);font-size:11px">'+prev+'</div>'
        +'<input type="number" placeholder="lbs" class="si" id="sw_'+letter+'_'+ei+'_'+si+'" value="'+(sd.w||'')+'">'
        +'<input type="number" placeholder="'+ex[2]+'" class="si" id="sr2_'+letter+'_'+ei+'_'+si+'" value="'+(sd.r||'')+'">'
        +'<div class="sc'+(sd.done?' on':'')+'" id="sc_'+letter+'_'+ei+'_'+si+'" onclick="togSet(letter,'+ei+','+si+')">'+( sd.done?'✓':'')+'</div>'
        +'</div>';
    }
    html+='</div>';
  });
  html+='<button class="fin-btn" onclick="finStr(letter)">Finish Workout ✓</button></div>';
  modal.innerHTML=html;modal.classList.add('open');document.body.style.overflow='hidden';
}

function getPrev(l,w,ei,si){
  for(var pw=w-1;pw>=1;pw--){
    var ps=ws(pw);
    if(ps.str&&ps.str[l]&&ps.str[l][ei]&&ps.str[l][ei][si]&&ps.str[l][ei][si].w)
      return ps.str[l][ei][si].w+'x'+(ps.str[l][ei][si].r||'?');
  }
  return '—';
}

function closeStr(l){document.getElementById('mod-'+l).classList.remove('open');document.body.style.overflow='';}

function togSet(l,ei,si){
  var ce=document.getElementById('sc_'+l+'_'+ei+'_'+si);
  var re=document.getElementById('sr_'+l+'_'+ei+'_'+si);
  if(!ce)return;
  var on=ce.classList.contains('on');
  ce.className='sc'+(on?'':' on');ce.textContent=on?'':'✓';
  if(re)re.className='set-r'+(on?'':' done');
  savStr(l);
}


function swExData(sel){swEx(sel.dataset.l,parseInt(sel.dataset.ei),sel.value);}

function swEx(l,ei,v){if(!v)return;var e=document.getElementById('en_'+l+'_'+ei);if(e)e.textContent=v;}

function savStr(l){
  var s=ws(curSW);if(!s.str)s.str={};if(!s.str[l])s.str[l]={};
  var exs=l==='A'?FBA:FBB;
  for(var ei=0;ei<exs.length;ei++){
    if(!s.str[l][ei])s.str[l][ei]={};
    for(var si=0;si<3;si++){
      var we=document.getElementById('sw_'+l+'_'+ei+'_'+si);
      var re=document.getElementById('sr2_'+l+'_'+ei+'_'+si);
      var ce=document.getElementById('sc_'+l+'_'+ei+'_'+si);
      s.str[l][ei][si]={w:we?we.value:'',r:re?re.value:'',done:ce?ce.classList.contains('on'):false};
    }
  }
  sv();
}

function finStr(l){
  savStr(l);closeStr(l);
  var dm={A:0,B:2},idx=dm[l];
  if(idx!==undefined){
    TW(curSW,idx);
  }
  toast('Workout complete! 💪');
}

function showScreen(id){
  document.getElementById('TRAIN').style.display=id==='TRAIN'?'block':'none';
  document.getElementById('PROG').style.display=id==='PROG'?'block':'none';
  document.getElementById('NUTR').style.display=id==='NUTR'?'block':'none';
  document.getElementById('ACT').style.display=id==='ACT'?'block':'none';
  document.getElementById('SET').style.display=id==='SET'?'block':'none';
  window.scrollTo(0,0);
}

// ── PROGRESS ──
function mkSVG(data,color,minY,maxY,fmtY,bars){
  var W=320,H=120,pl=32,pr=8,pt=8,pb=18;
  var cw2=W-pl-pr,ch=H-pt-pb;
  var valid=data.map(function(v,i){return{v:v,i:i};}).filter(function(d){return d.v!==null&&!isNaN(d.v);});
  var yMn=minY!==null?minY:(valid.length?Math.min.apply(null,valid.map(function(d){return d.v;})):0);
  var yMx=maxY!==null?maxY:(valid.length?Math.max.apply(null,valid.map(function(d){return d.v;})):10);
  if(yMn===yMx){yMn-=1;yMx+=1;}
  var xS=cw2/16;
  function px(i){return pl+i*xS;}
  function py(v){return pt+ch-((v-yMn)/(yMx-yMn))*ch;}
  var s='<svg viewBox="0 0 '+W+' '+H+'" width="100%" style="display:block;overflow:visible">';
  for(var g=0;g<=4;g++){
    var gv=yMn+(yMx-yMn)*(g/4),gy=py(gv);
    s+='<line x1="'+pl+'" y1="'+gy+'" x2="'+(W-pr)+'" y2="'+gy+'" stroke="rgba(255,255,255,.06)" stroke-width="1"/>';
    s+='<text x="'+(pl-3)+'" y="'+(gy+3)+'" font-size="7" fill="rgba(255,255,255,.25)" text-anchor="end" font-family="-apple-system,sans-serif">'+(fmtY?fmtY(gv):Math.round(gv))+'</text>';
  }
  for(var xi=0;xi<=16;xi+=4)s+='<text x="'+px(xi)+'" y="'+(H-3)+'" font-size="7" fill="rgba(255,255,255,.22)" text-anchor="middle" font-family="-apple-system,sans-serif" letter-spacing="0">W'+(xi+1)+'</text>';
  if(bars){
    var bw=xS*0.6;
    data.forEach(function(v,i){
      if(v===null||isNaN(v))return;
      var bh=(v/yMx)*ch,bx=px(i)-bw/2,by=pt+ch-bh;
      var bc=v>=5?'#00C896':v>=3?'#FFB938':'#FF5B5B';
      if(v>0)s+='<rect x="'+bx+'" y="'+by+'" width="'+bw+'" height="'+bh+'" fill="'+bc+'" rx="3"/>';
    });
  }else if(valid.length>1){
    var area='M '+px(valid[0].i)+' '+py(yMn)+' L '+px(valid[0].i)+' '+py(valid[0].v);
    for(var vi=1;vi<valid.length;vi++)area+=' L '+px(valid[vi].i)+' '+py(valid[vi].v);
    area+=' L '+px(valid[valid.length-1].i)+' '+py(yMn)+' Z';
    s+='<path d="'+area+'" fill="'+color+'" opacity="0.1"/>';
    s+='<path d="M '+valid.map(function(d){return px(d.i)+' '+py(d.v);}).join(' L ')+'" fill="none" stroke="'+color+'" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>';
    valid.forEach(function(d){s+='<circle cx="'+px(d.i)+'" cy="'+py(d.v)+'" r="3.5" fill="white" stroke="'+color+'" stroke-width="2"/>';});
  }else if(valid.length===1){
    s+='<circle cx="'+px(valid[0].i)+'" cy="'+py(valid[0].v)+'" r="5" fill="'+color+'"/>';
  }else{
    s+='<text x="'+(W/2)+'" y="'+(H/2)+'" font-size="12" fill="rgba(255,255,255,.2)" text-anchor="middle">No data yet</text>';
  }
  return s+'</svg>';
}

function showProg(){
  var wts=[],ens=[],sls=[],cos=[];
  for(var w=1;w<=17;w++){
    var s=ws(w);
    wts.push(s.ci&&s.ci.weight?parseFloat(s.ci.weight):null);
    ens.push(s.ci&&s.ci.energy?parseFloat(s.ci.energy):null);
    sls.push(s.ci&&s.ci.sleep?parseFloat(s.ci.sleep):null);
    cos.push(Object.values(s.wo).filter(Boolean).length);
  }
  var td=cos.reduce(function(a,b){return a+b;},0);
  var wl=wts.filter(function(v){return v!==null;}).length;
  var fw=null,lw=null;
  for(var i=0;i<wts.length;i++){if(wts[i]!==null&&fw===null)fw=wts[i];}
  for(var i=wts.length-1;i>=0;i--){if(wts[i]!==null){lw=wts[i];break;}}
  var wch=fw!==null&&lw!==null&&fw!==lw?(lw-fw).toFixed(1):null;
  var ae=ens.filter(function(v){return v!==null;});
  var pct=Math.min(100,Math.round((td/102)*100));
  var r=48,circ=2*Math.PI*r,dash=circ*(pct/100),gap=circ-dash;

  var html='<div style="padding:14px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--b1)">'
    +'<button class="back-btn" onclick="showTrain()">&#8592; Back</button>'
    +'<div style="font-size:19px;font-weight:800">Progress</div></div>';

  html+='<div style="padding:18px 16px 0;display:flex;align-items:center;gap:14px">'
    +'<svg width="110" height="110" viewBox="0 0 120 120" style="flex-shrink:0">'
    +'<defs><linearGradient id="pg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#00C896"/><stop offset="100%" stop-color="#0095C8"/></linearGradient></defs>'
    +'<circle cx="60" cy="60" r="'+r+'" fill="none" stroke="var(--s3)" stroke-width="9"/>'
    +'<circle cx="60" cy="60" r="'+r+'" fill="none" stroke="url(#pg)" stroke-width="9" stroke-dasharray="'+dash+' '+gap+'" transform="rotate(-90 60 60)" stroke-linecap="round"/>'
    +'<text x="60" y="57" text-anchor="middle" font-size="20" font-weight="800" fill="var(--t1)" font-family="-apple-system,sans-serif">'+pct+'%</text>'
    +'<text x="60" y="72" text-anchor="middle" font-size="9" fill="var(--t3)" font-family="-apple-system,sans-serif">COMPLETE</text>'
    +'</svg>'
    +'<div style="flex:1;display:grid;grid-template-columns:1fr 1fr;gap:8px">'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Done</div><div style="font-size:22px;font-weight:800;color:var(--green)">'+td+'</div></div>'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Weeks</div><div style="font-size:22px;font-weight:800;color:var(--blue)">'+wl+'/17</div></div>'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Weight</div><div style="font-size:22px;font-weight:800;color:var(--gold)">'+(wch?(parseFloat(wch)>0?'+':'')+wch:'—')+'</div></div>'
    +'<div style="background:var(--s1);border-radius:12px;border:1px solid var(--b1);padding:10px"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px">Energy</div><div style="font-size:22px;font-weight:800;color:var(--purple)">'+(ae.length?(ae.reduce(function(a,b){return a+b;},0)/ae.length).toFixed(1):'—')+'</div></div>'
    +'</div></div>';

  var phases=[{n:"Foundation",w:[1,2,3,4],c:"#4D9FFF"},{n:"Aerobic Build",w:[5,6,7,8,9,10],c:"#00C896"},{n:"Race-Specific",w:[11,12,13,14,15],c:"#FFB938"},{n:"Taper & Race",w:[16,17],c:"#FF7A45"}];
  html+='<div style="padding:16px 16px 0">';
  phases.forEach(function(ph){
    var pd=0,pt2=0;ph.w.forEach(function(w){var s=ws(w);pd+=Object.values(s.wo).filter(Boolean).length;pt2+=WC[w];});
    var pp=pt2>0?Math.round((pd/pt2)*100):0;
    html+='<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;margin-bottom:5px"><span style="font-size:13px;font-weight:600;color:var(--t1)">'+ph.n+'</span><span style="font-size:12px;font-weight:700;color:'+ph.c+'">'+pp+'%</span></div>'
      +'<div style="height:6px;background:var(--s3);border-radius:3px"><div style="height:6px;background:'+ph.c+';border-radius:3px;width:'+pp+'%"></div></div></div>';
  });
  html+='</div>';

  html+='<div style="padding:0 16px"><div style="display:flex;gap:3px;background:var(--s2);border-radius:10px;padding:3px;margin-bottom:12px">'
    +'<button onclick="sCT(0)" id="ct0" style="flex:1;padding:7px 4px;border:none;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;font-family:-apple-system,sans-serif;background:var(--s1);color:var(--t1)">Weight</button>'
    +'<button onclick="sCT(1)" id="ct1" style="flex:1;padding:7px 4px;border:none;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;font-family:-apple-system,sans-serif;background:transparent;color:var(--t3)">Sessions</button>'
    +'<button onclick="sCT(2)" id="ct2" style="flex:1;padding:7px 4px;border:none;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;font-family:-apple-system,sans-serif;background:transparent;color:var(--t3)">Energy</button>'
    +'<button onclick="sCT(3)" id="ct3" style="flex:1;padding:7px 4px;border:none;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;font-family:-apple-system,sans-serif;background:transparent;color:var(--t3)">Sleep</button>'
    +'</div>'
    +'<div style="background:var(--s1);border-radius:14px;border:1px solid var(--b1);padding:14px">'
    +'<div id="cc0">'+mkSVG(wts,'#00C896',null,null,function(v){return Math.round(v)+'lb';},false)+'</div>'
    +'<div id="cc1" style="display:none">'+mkSVG(cos,'#4D9FFF',0,6,null,true)+'</div>'
    +'<div id="cc2" style="display:none">'+mkSVG(ens,'#FFB938',1,10,null,false)+'</div>'
    +'<div id="cc3" style="display:none">'+mkSVG(sls,'#A78BFA',4,10,function(v){return v+'h';},false)+'</div>'
    +'</div></div>';

  html+='<div style="padding:16px 16px 8px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3)">Weekly Log</div>';
  var phColors={1:'#4D9FFF',2:'#4D9FFF',3:'#4D9FFF',4:'#4D9FFF',5:'#00C896',6:'#00C896',7:'#00C896',8:'#00C896',9:'#00C896',10:'#00C896',11:'#FFB938',12:'#FFB938',13:'#FFB938',14:'#FFB938',15:'#FFB938',16:'#FF7A45',17:'#FF7A45'};
  for(var w=1;w<=17;w++){
    var s=ws(w),d=Object.values(s.wo).filter(Boolean).length;
    var has=d>0||(s.ci&&(s.ci.weight||s.ci.notes));
    var pp2=WC[w]>0?Math.round((d/WC[w])*100):0;
    var bc=pp2>=80?'var(--green)':pp2>=50?'var(--gold)':'var(--red)';
    html+='<div style="margin:0 16px 8px;display:flex;gap:10px;align-items:flex-start">'
      +'<div style="flex-shrink:0;display:flex;flex-direction:column;align-items:center;padding-top:14px">'
      +'<div style="width:9px;height:9px;border-radius:50%;background:'+(has?phColors[w]:'var(--s3)')+'"></div>'
      +(w>1?'<div style="width:2px;min-height:28px;background:var(--s3);margin-top:3px;flex:1"></div>':'')
      +'</div>'
      +'<div style="flex:1;background:var(--s1);border-radius:14px;border:1px solid var(--b1);padding:12px">'
      +'<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:'+(has?'8':'0')+'px">'
      +'<div><span style="font-size:14px;font-weight:800">Week '+w+'</span><span style="font-size:11px;color:var(--t3);margin-left:7px">'+(PHASES[w]?PHASES[w][0]:'')+'</span></div>'
      +(has?'<span style="font-size:12px;font-weight:700;color:'+bc+'">'+d+'/'+WC[w]+'</span>':'<span style="font-size:11px;color:var(--s3)">—</span>')
      +'</div>';
    if(has){
      html+='<div style="height:3px;background:var(--s3);border-radius:2px;margin-bottom:8px"><div style="height:3px;background:'+bc+';border-radius:2px;width:'+pp2+'%"></div></div>';
      var m=[];
      if(s.ci&&s.ci.weight)m.push('⚖️ '+s.ci.weight+' lbs');
      if(s.ci&&s.ci.rhr)m.push('❤️ '+s.ci.rhr);
      if(s.ci&&s.ci.energy)m.push('⚡ '+s.ci.energy+'/10');
      if(s.ci&&s.ci.sleep)m.push('🌙 '+s.ci.sleep+'h');
      if(m.length)html+='<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:6px">'+m.map(function(x){return '<span style="background:var(--s2);border-radius:8px;padding:3px 8px;font-size:11px;color:var(--t2)">'+x+'</span>';}).join('')+'</div>';
      if(s.ci&&s.ci.notes)html+='<div style="font-size:11px;color:var(--t3);font-style:italic;padding-top:6px;border-top:1px solid var(--b1)">"'+s.ci.notes+'"</div>';
    }
    html+='</div></div>';
  }
  html+='<div style="height:50px"></div>';
  document.getElementById('PROG').innerHTML=html;
  showScreen('PROG');
}

function sCT(i){
  for(var j=0;j<4;j++){
    var t=document.getElementById('ct'+j),c=document.getElementById('cc'+j);
    if(t){t.style.background=j===i?'var(--s1)':'transparent';t.style.color=j===i?'var(--t1)':'var(--t3)';}
    if(c)c.style.display=j===i?'block':'none';
  }
}

// Settings, Nutrition, Activity screens injected dynamically but with no quote issues
function showSet(){
  var total=0;for(var w=1;w<=17;w++)total+=Object.values(ws(w).wo).filter(Boolean).length;
  var html='<div style="padding:14px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--b1)">'
    +'<button class="back-btn" onclick="showTrain()">&#8592; Back</button>'
    +'<div style="font-size:19px;font-weight:800">Settings</div></div>';
  html+='<div style="background:var(--s1);margin:14px 16px 10px;border-radius:14px;border:1px solid var(--b1);overflow:hidden">'
    +'<div style="background:var(--s3);padding:9px 16px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3)">Profile</div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:14px 16px">'
    +'<div><div class="ci-lbl">Name</div><input class="ci-in" value="'+(st.profileName||'Mikey')+'" id="set-name"></div>'
    +'<div><div class="ci-lbl">Weight (lbs)</div><input class="ci-in" type="number" value="'+(st.weight||'')+'" placeholder="162" id="set-wt"></div>'
    +'<div><div class="ci-lbl">FTP (watts)</div><input class="ci-in" type="number" value="'+(st.ftp||'')+'" placeholder="185" id="set-ftp"></div>'
    +'<div><div class="ci-lbl">Current Week</div><div style="font-size:22px;font-weight:800;color:var(--green);margin-top:4px">Week '+cw+'</div></div>'
    +'</div>'
    +'<div style="padding:0 16px 14px;display:flex;gap:8px">'
    +'<button onclick="saveProfile()" style="background:linear-gradient(135deg,#00C896,#0095C8);border:none;color:white;font-size:13px;font-weight:700;padding:10px 20px;border-radius:10px;cursor:pointer">Save Profile</button>'
    +'</div></div>';
  html+='<div style="background:var(--s1);margin:0 16px 10px;border-radius:14px;border:1px solid var(--b1);overflow:hidden">'
    +'<div style="background:var(--s3);padding:9px 16px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3)">Stats</div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--b1)">'
    +'<div style="background:var(--s1);padding:14px 16px"><div class="ci-lbl">Workouts Done</div><div style="font-size:22px;font-weight:800;color:var(--green)">'+total+'</div></div>'
    +'<div style="background:var(--s1);padding:14px 16px"><div class="ci-lbl">Activities</div><div style="font-size:22px;font-weight:800;color:var(--blue)">'+(st.activities?st.activities.length:0)+'</div></div>'
    +'</div></div>';
  html+='<div style="background:var(--s1);margin:0 16px 10px;border-radius:14px;border:1px solid var(--b1);padding:14px 16px">'
    +'<div class="ci-lbl" style="margin-bottom:10px">Data &amp; Backup</div>'
    +'<div style="display:flex;gap:10px;flex-wrap:wrap">'
    +'<button onclick="expData()" style="background:linear-gradient(135deg,#00C896,#0095C8);border:none;color:white;font-size:13px;font-weight:700;padding:10px 18px;border-radius:10px;cursor:pointer">⬇️ Export</button>'
    +'<button onclick="impData()" style="background:var(--s2);border:1px solid var(--b2);color:var(--t2);font-size:13px;font-weight:700;padding:10px 18px;border-radius:10px;cursor:pointer">⬆️ Restore</button>'
    +'</div></div>';
  html+='<div style="height:50px"></div>';
  document.getElementById('SET').innerHTML=html;
  showScreen('SET');
}

function saveProfile(){
  var n=document.getElementById('set-name');
  var w=document.getElementById('set-wt');
  var f=document.getElementById('set-ftp');
  if(n)st.profileName=n.value;
  if(w&&w.value)st.weight=w.value;
  if(f&&f.value)st.ftp=parseInt(f.value);
  sv();toast('Profile saved!');
}

function expData(){
  var blob=new Blob([JSON.stringify({v:1,d:st},null,2)],{type:'application/json'});
  var url=URL.createObjectURL(blob);
  var a=document.createElement('a');a.href=url;a.download='mikey_backup_'+new Date().toISOString().split('T')[0]+'.json';
  document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);
  toast('Backup downloaded!');
}
function impData(){
  var inp=document.createElement('input');inp.type='file';inp.accept='.json';
  inp.onchange=function(e){
    var f=e.target.files[0];if(!f)return;
    var r=new FileReader();
    r.onload=function(ev){try{var p=JSON.parse(ev.target.result);if(p.d){st=p.d;sv();showTrain();toast('Restored!');}}catch(er){toast('Invalid file');}};
    r.readAsText(f);
  };
  inp.click();
}

