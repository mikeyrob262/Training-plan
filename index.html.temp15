<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Training">
<meta name="theme-color" content="#252D3A">
<title>Mikey's Training App</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#252D3A;--s1:#2E3849;--s2:#36435A;--s3:#3F506E;
  --b1:rgba(255,255,255,.08);--b2:rgba(255,255,255,.14);
  --t1:#F0F4FF;--t2:#8B9BB4;--t3:#5A6A84;
  --green:#00C896;--blue:#4D9FFF;--red:#FF5B5B;--gold:#FFB938;--purple:#A78BFA;--orange:#FF7A45
}
body{font-family:-apple-system,sans-serif;background:var(--bg);color:var(--t1);min-height:100vh}
.hdr{background:linear-gradient(180deg,#2C3749,#252D3A);padding:14px 16px 10px;position:sticky;top:0;z-index:100;border-bottom:1px solid var(--b1)}
.hdr-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.logo{display:flex;align-items:center;gap:8px}
.logo-ic{width:28px;height:28px;background:linear-gradient(135deg,#00C896,#0095C8);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px}
.logo-tx{font-size:14px;font-weight:700;color:var(--t1)}
.hdr-btns{display:flex;gap:5px;align-items:center}
.hbtn{background:var(--s2);border:1px solid var(--b2);color:var(--t2);width:34px;height:34px;border-radius:9px;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.phase-pill{background:linear-gradient(135deg,#00C896,#0095C8);color:white;font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px}
.hdr-nav{display:flex;align-items:center;gap:10px}
.narr{background:var(--s2);border:1px solid var(--b2);color:var(--t2);width:36px;height:36px;border-radius:10px;font-size:20px;cursor:pointer}
.narr:disabled{opacity:.25}
.wi{flex:1}
.wph{font-size:12px;font-weight:600;color:var(--green);margin-bottom:1px}
.wtit{font-size:20px;font-weight:800;color:var(--t1);cursor:pointer;background:none;border:none;padding:0}
.dots{display:flex;gap:3px;overflow-x:auto;scrollbar-width:none;padding:7px 0 2px}
.dots::-webkit-scrollbar{display:none}
.dot{flex-shrink:0;height:4px;width:14px;border-radius:2px;cursor:pointer;background:rgba(255,255,255,.15)}
.dot.done{background:var(--green);width:16px}
.dot.cur{background:white;width:22px}
.wk{padding-bottom:20px}
.goal{background:linear-gradient(135deg,rgba(0,200,150,.15),rgba(0,149,200,.1));border:1px solid rgba(0,200,150,.2);border-radius:14px;padding:13px 16px;margin:14px 16px 0}
.goal-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--green);margin-bottom:4px}
.goal-txt{font-size:14px;color:var(--t1);font-weight:500;line-height:1.4}
.sec-title{padding:18px 16px 8px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3)}
.wo-card{background:var(--s1);margin:0 16px 10px;border-radius:14px;border:1px solid var(--b1);overflow:hidden}
.wo-main{display:flex;align-items:flex-start;padding:14px;gap:12px}
.wo-chk{width:26px;height:26px;border:2px solid var(--b2);border-radius:50%;flex-shrink:0;cursor:pointer;margin-top:2px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white;transition:all .15s}
.wo-chk.on{background:var(--green);border-color:var(--green)}
.wo-day{font-size:11px;font-weight:700;color:var(--t3);letter-spacing:.06em}
.wo-sess{font-size:15px;font-weight:700;color:var(--t1);margin:2px 0}
.wo-det{font-size:13px;color:var(--t2);line-height:1.45}
.str-btn{margin-top:9px;background:rgba(0,200,150,.12);border:1px solid rgba(0,200,150,.25);color:var(--green);font-size:12px;font-weight:700;padding:6px 13px;border-radius:20px;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px}
.swap-sm{margin-top:6px;margin-left:6px;background:transparent;border:1px solid var(--b2);color:var(--t3);font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;cursor:pointer;font-family:inherit}
.wo-ft{border-top:1px solid var(--b1);display:flex;padding:10px 14px;gap:10px;background:var(--s2)}
.wof{flex:1}
.wof-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:3px}
.wof-pl{font-size:12px;color:var(--t2);font-weight:500}
.wof-in{font-size:13px;border:none;border-bottom:1px solid var(--b2);background:transparent;color:var(--t1);width:100%;padding:2px 0;font-family:inherit}
.wof-in::placeholder{color:var(--t3)}
.badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;white-space:nowrap}
.bh{background:rgba(255,91,91,.12);color:#FF5B5B;border:1px solid rgba(255,91,91,.2)}
.bm{background:rgba(77,159,255,.12);color:#4D9FFF;border:1px solid rgba(77,159,255,.2)}
.be{background:rgba(0,200,150,.12);color:#00C896;border:1px solid rgba(0,200,150,.2)}
.bem{background:rgba(255,185,56,.12);color:#FFB938;border:1px solid rgba(255,185,56,.2)}
.br{background:var(--s2);color:var(--t3);border:1px solid var(--b1)}
.nt-wrap{background:var(--s1);margin:0 16px 10px;border-radius:14px;border:1px solid var(--b1);overflow:hidden}
.nt-head{display:grid;grid-template-columns:36px 46px 90px 60px 100px 1fr 1fr 24px;background:var(--s3);padding:8px 12px;gap:5px;font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3)}
.nt-row{display:grid;grid-template-columns:36px 46px 90px 60px 100px 1fr 1fr 24px;padding:9px 12px;gap:5px;border-top:1px solid var(--b1);align-items:center}
.nt-row.alt{background:rgba(255,255,255,.02)}
.nt-day{font-size:12px;font-weight:700;color:var(--t1)}
.nbdg{font-size:9px;font-weight:700;padding:2px 7px;border-radius:10px}
.nt-v{font-size:10px;color:var(--t2);line-height:1.3}
.nt-c{font-size:10px;font-weight:700;color:var(--t1)}
.nt-chk{width:20px;height:20px;border:2px solid var(--b2);border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:white;transition:all .15s;justify-self:center}
.nt-chk.on{background:var(--green);border-color:var(--green)}
.ci-card{background:var(--s1);margin:0 16px 10px;border-radius:14px;border:1px solid var(--b1);overflow:hidden}
.ci-hdr{background:var(--s3);padding:10px 16px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3)}
.ci-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--b1)}
.ci-f{background:var(--s1);padding:12px 16px}
.ci-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:5px}
.ci-in{font-size:18px;border:none;border-bottom:1.5px solid var(--b2);background:transparent;color:var(--t1);width:100%;font-weight:700;padding:0;font-family:inherit}
.ci-in::placeholder{color:var(--t3)}
.ci-notes{padding:12px 16px;background:var(--s1)}
.ci-ta{font-size:14px;border:none;border-bottom:1.5px solid var(--b2);background:transparent;color:var(--t1);width:100%;padding:0;resize:none;font-family:inherit}
.ci-ta::placeholder{color:var(--t3)}
input:focus,.ci-in:focus,.wof-in:focus,.ci-ta:focus{outline:none;border-bottom-color:var(--green)!important}
.swap-panel{padding:12px 14px;background:var(--s3);border-top:1px solid var(--b2)}
.swap-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--blue);margin-bottom:8px}
.swap-opts{display:flex;flex-wrap:wrap;gap:6px}
.swap-opt{background:var(--s2);border:1px solid var(--b2);color:var(--blue);font-size:12px;font-weight:600;padding:6px 12px;border-radius:20px;cursor:pointer;font-family:inherit}
.swap-cancel{background:transparent;border:1px solid var(--b1);color:var(--t3);font-size:12px;font-weight:600;padding:6px 12px;border-radius:20px;cursor:pointer;font-family:inherit}
.pk-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:150;display:none}
.pk-bg.open{display:block}
.pk-sheet{position:fixed;bottom:0;left:0;right:0;background:var(--s1);border-radius:22px 22px 0 0;padding:16px;z-index:200;transform:translateY(100%);transition:transform .3s ease;max-height:70vh;overflow-y:auto;border-top:1px solid var(--b2)}
.pk-sheet.open{transform:translateY(0)}
.pk-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:12px}
.pk-it{background:var(--s2);border:1px solid var(--b1);border-radius:10px;padding:12px 8px;text-align:center;cursor:pointer}
.pk-n{font-size:18px;font-weight:800;color:var(--t1)}
.pk-p{font-size:9px;color:var(--t3);margin-top:2px}
.pk-it.cur{background:rgba(0,200,150,.12);border-color:rgba(0,200,150,.3)}
.pk-it.cur .pk-n{color:var(--green)}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;display:none;align-items:flex-end}
.modal-bg.open{display:flex}
.modal-sh{background:var(--s1);border-radius:22px 22px 0 0;width:100%;max-height:90vh;overflow-y:auto;padding-bottom:30px;border-top:1px solid var(--b2)}
.mhdl{width:40px;height:4px;background:var(--b2);border-radius:2px;margin:13px auto 0}
.mhdr{display:flex;justify-content:space-between;align-items:center;padding:14px 18px 8px}
.mtit{font-size:19px;font-weight:800;color:var(--t1)}
.mclose{background:var(--s2);border:1px solid var(--b1);color:var(--t2);width:30px;height:30px;border-radius:50%;font-size:15px;cursor:pointer}
.ex-c{background:var(--s2);margin:8px 16px;border-radius:12px;border:1px solid var(--b1);overflow:hidden}
.ex-h{padding:12px 14px 8px;display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
.ex-nm{font-size:15px;font-weight:700;color:var(--t1)}
.ex-tip{font-size:11px;color:var(--t3);margin-top:2px}
.ex-sw{font-size:11px;border:1px solid var(--b2);border-radius:8px;padding:4px 8px;background:var(--s1);color:var(--blue);font-weight:600;cursor:pointer;max-width:130px}
.set-hr,.set-r{display:grid;grid-template-columns:26px 1fr 68px 68px 32px;gap:6px;padding:8px 14px;align-items:center;border-top:1px solid var(--b1)}
.sn{font-size:12px;font-weight:700;color:var(--t3);text-align:center}
.sp{font-size:11px;color:var(--t3);text-align:center}
.si{font-size:14px;border:none;border-bottom:1.5px solid var(--b2);background:transparent;text-align:center;padding:3px 0;width:100%;color:var(--t1);font-family:inherit}
.si::placeholder{color:var(--t3)}
.sc{width:26px;height:26px;border:2px solid var(--b2);border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white;background:transparent;justify-self:center;transition:all .15s}
.sc.on{background:var(--green);border-color:var(--green)}
.set-r.done{background:rgba(0,200,150,.05)}
.fin-btn{margin:16px;background:linear-gradient(135deg,#00C896,#0095C8);border:none;color:white;font-size:16px;font-weight:700;padding:15px;border-radius:13px;width:calc(100% - 32px);cursor:pointer}
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:var(--s2);border:1px solid var(--b2);color:var(--t1);padding:11px 18px;border-radius:28px;font-size:13px;font-weight:600;z-index:9999;pointer-events:none;white-space:nowrap}
.back-btn{background:var(--s2);border:1px solid var(--b1);color:var(--t2);font-size:13px;font-weight:600;padding:6px 14px;border-radius:20px;cursor:pointer}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-top">
    <div class="logo"><div class="logo-ic">🏆</div><span class="logo-tx">Mikey's Training App</span></div>
    <div class="hdr-btns">
      <button class="hbtn" id="btn-prog">📊</button>
      <button class="hbtn" id="btn-nutr">🥗</button>
      <button class="hbtn" id="btn-act">🚴</button>
      <button class="hbtn" id="btn-set">⚙️</button>
      <span class="phase-pill" id="pp">Phase 1</span>
    </div>
  </div>
  <div class="hdr-nav">
    <button class="narr" id="btn-pv">&#8249;</button>
    <div class="wi">
      <div class="wph" id="wph">Foundation</div>
      <button class="wtit" id="btn-wt">Week 1 <span style="font-size:13px;opacity:.4">&#9660;</span></button>
    </div>
    <button class="narr" id="btn-nx">&#8250;</button>
  </div>
  <div class="dots" id="dots"><div id="pd1" class="dot" onclick="GW(1)"></div><div id="pd2" class="dot" onclick="GW(2)"></div><div id="pd3" class="dot" onclick="GW(3)"></div><div id="pd4" class="dot" onclick="GW(4)"></div><div id="pd5" class="dot" onclick="GW(5)"></div><div id="pd6" class="dot" onclick="GW(6)"></div><div id="pd7" class="dot" onclick="GW(7)"></div><div id="pd8" class="dot" onclick="GW(8)"></div><div id="pd9" class="dot" onclick="GW(9)"></div><div id="pd10" class="dot" onclick="GW(10)"></div><div id="pd11" class="dot" onclick="GW(11)"></div><div id="pd12" class="dot" onclick="GW(12)"></div><div id="pd13" class="dot" onclick="GW(13)"></div><div id="pd14" class="dot" onclick="GW(14)"></div><div id="pd15" class="dot" onclick="GW(15)"></div><div id="pd16" class="dot" onclick="GW(16)"></div><div id="pd17" class="dot" onclick="GW(17)"></div></div>
</div>

<div id="TRAIN">
<div id="W1" class="wk">
<div class="goal"><div class="goal-lbl">Week Goal</div><div class="goal-txt">Build the habit. Easy stays easy. Hit protein every day.</div></div>
<div class="sec-title">Training Schedule</div>
<div class="wo-card" id="wc1_0">
<div class="wo-main">
  <div class="wo-chk" id="ck1_0" onclick="TW(1,0)"></div>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px">
      <span class="wo-day">MON</span><span class="badge bm">MODERATE</span>
    </div>
    <div class="wo-sess" id="ws1_0">Strength A</div>
    <div class="wo-det">Full Body A — Goblet squat, RDL, Bench, Push-up, Band row, Dead bug</div>
    <button class="str-btn" onclick="openStr('A',1)">💪 Log Full Body A</button><button class="swap-sm" onclick="doSwap(1,0,this)">🔄 Swap</button>
  </div>
</div><div class="wo-ft">
  <div class="wof"><div class="wof-lbl">Planned</div><div class="wof-pl">45-55 min</div></div>
  <div class="wof"><div class="wof-lbl">Actual</div><input class="wof-in" type="text" placeholder="e.g. 52 min" id="af1_0" onchange="SF(1,0,'a',this.value)"></div>
  <div class="wof" style="flex:0 0 55px"><div class="wof-lbl">RPE</div><input class="wof-in" type="text" placeholder="—" id="rf1_0" onchange="SF(1,0,'r',this.value)"></div>
</div>
</div>
<div class="wo-card" id="wc1_1">
<div class="wo-main">
  <div class="wo-chk" id="ck1_1" onclick="TW(1,1)"></div>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px">
      <span class="wo-day">TUE</span><span class="badge be">EASY</span>
    </div>
    <div class="wo-sess" id="ws1_1">Zwift</div>
    <div class="wo-det">Zone 2 Endurance — 45 min 65-75% FTP (~119-137w) steady</div>
    <button class="swap-sm" onclick="doSwap(1,1,this)">🔄 Swap</button>
  </div>
</div><div class="wo-ft">
  <div class="wof"><div class="wof-lbl">Planned</div><div class="wof-pl">45-60 min</div></div>
  <div class="wof"><div class="wof-lbl">Actual</div><input class="wof-in" type="text" placeholder="e.g. 52 min" id="af1_1" onchange="SF(1,1,'a',this.value)"></div>
  <div class="wof" style="flex:0 0 55px"><div class="wof-lbl">RPE</div><input class="wof-in" type="text" placeholder="—" id="rf1_1" onchange="SF(1,1,'r',this.value)"></div>
</div>
</div>
<div class="wo-card" id="wc1_2">
<div class="wo-main">
  <div class="wo-chk" id="ck1_2" onclick="TW(1,2)"></div>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px">
      <span class="wo-day">WED</span><span class="badge bem">EASY/MOD</span>
    </div>
    <div class="wo-sess" id="ws1_2">Run + Strength B</div>
    <div class="wo-det">Easy run 20-25 min RPE 3-4 + Full Body B — 30 min</div>
    <button class="str-btn" onclick="openStr('B',1)">💪 Log Full Body B</button><button class="swap-sm" onclick="doSwap(1,2,this)">🔄 Swap</button>
  </div>
</div><div class="wo-ft">
  <div class="wof"><div class="wof-lbl">Planned</div><div class="wof-pl">50-65 min</div></div>
  <div class="wof"><div class="wof-lbl">Actual</div><input class="wof-in" type="text" placeholder="e.g. 52 min" id="af1_2" onchange="SF(1,2,'a',this.value)"></div>
  <div class="wof" style="flex:0 0 55px"><div class="wof-lbl">RPE</div><input class="wof-in" type="text" placeholder="—" id="rf1_2" onchange="SF(1,2,'r',this.value)"></div>
</div>
</div>
<div class="wo-card" id="wc1_3">
<div class="wo-main">
  <div class="wo-chk" id="ck1_3" onclick="TW(1,3)"></div>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px">
      <span class="wo-day">THU</span><span class="badge bh">HARD</span>
    </div>
    <div class="wo-sess" id="ws1_3">Chase 2</div>
    <div class="wo-det">Group Ride ~18-21 mph 1.5-2 hrs — hold wheels, no attacks</div>
    <button class="swap-sm" onclick="doSwap(1,3,this)">🔄 Swap</button>
  </div>
</div><div class="wo-ft">
  <div class="wof"><div class="wof-lbl">Planned</div><div class="wof-pl">1.5-2 hrs</div></div>
  <div class="wof"><div class="wof-lbl">Actual</div><input class="wof-in" type="text" placeholder="e.g. 52 min" id="af1_3" onchange="SF(1,3,'a',this.value)"></div>
  <div class="wof" style="flex:0 0 55px"><div class="wof-lbl">RPE</div><input class="wof-in" type="text" placeholder="—" id="rf1_3" onchange="SF(1,3,'r',this.value)"></div>
</div>
</div>
<div class="wo-card" id="wc1_4">
<div class="wo-main">
  <div class="wo-chk" id="ck1_4" onclick="TW(1,4)"></div>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px">
      <span class="wo-day">FRI</span><span class="badge be">EASY</span>
    </div>
    <div class="wo-sess" id="ws1_4">Easy Run</div>
    <div class="wo-det">Easy run 20-25 min RPE 3-4 only — legs tired from Thu</div>
    <button class="swap-sm" onclick="doSwap(1,4,this)">🔄 Swap</button>
  </div>
</div><div class="wo-ft">
  <div class="wof"><div class="wof-lbl">Planned</div><div class="wof-pl">20-35 min</div></div>
  <div class="wof"><div class="wof-lbl">Actual</div><input class="wof-in" type="text" placeholder="e.g. 52 min" id="af1_4" onchange="SF(1,4,'a',this.value)"></div>
  <div class="wof" style="flex:0 0 55px"><div class="wof-lbl">RPE</div><input class="wof-in" type="text" placeholder="—" id="rf1_4" onchange="SF(1,4,'r',this.value)"></div>
</div>
</div>
<div class="wo-card" id="wc1_5">
<div class="wo-main">
  <div class="wo-chk" id="ck1_5" onclick="TW(1,5)"></div>
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px">
      <span class="wo-day">SAT</span><span class="badge bm">MODERATE</span>
    </div>
    <div class="wo-sess" id="ws1_5">Outdoor Ride</div>
    <div class="wo-det">Endurance ride 1.5-2 hrs Zone 2, RPE 4-5</div>
    <button class="swap-sm" onclick="doSwap(1,5,this)">🔄 Swap</button>
  </div>
</div><div class="wo-ft">
  <div class="wof"><div class="wof-lbl">Planned</div><div class="wof-pl">1.5-2.5 hrs</div></div>
